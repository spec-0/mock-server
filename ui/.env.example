# =============================================================================
# Mock Server UI — environment (copy to .env.local for local overrides)
# =============================================================================
#
# Next.js inlines NEXT_PUBLIC_* at build time for production. For `next dev`,
# changes here take effect after restarting the dev server.
#
# When to use this file:
# - API runs on a host/port other than http://localhost:8080
# - You use a non-default dev port for Next (not 3000/3001) and need an explicit API URL
#
# If you only run: API on :8080 + `npm run dev` on :3000 — you usually do NOT need this file.
# =============================================================================

# Primary: base URL of the Spring Boot mock server (no trailing slash)
NEXT_PUBLIC_MOCK_SERVER_API_URL=http://localhost:8080

# Optional alias — same meaning as NEXT_PUBLIC_MOCK_SERVER_API_URL (set one or the other)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional legacy alias (prefer NEXT_PUBLIC_MOCK_SERVER_API_URL)
# NEXT_PUBLIC_STANDALONE_URL=http://localhost:8080
